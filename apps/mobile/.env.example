# Public Firebase WEB config for the Expo app (RULE 3 — these are NOT secrets;
# the shared @soteria/firebase package reads EXPO_PUBLIC_FIREBASE_* at build time).
# Server-only secrets (ANTHROPIC_API_KEY, etc.) live ONLY in Firebase Functions.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Defaults to 830573978482 (the project number) when omitted.
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=830573978482

# Set to "true" to point Auth/Firestore/Storage at the local emulator suite.
EXPO_PUBLIC_USE_EMULATOR=false
