{
  "name": "soteria-assurance",
  "version": "1.0.0",
  "private": true,
  "description": "ISO 45001:2018 AI-powered audit management platform — Turborepo monorepo",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "dev:web": "turbo run dev --filter=@soteria/web",
    "dev:mobile": "turbo run dev --filter=@soteria/mobile",
    "dev:functions": "turbo run dev --filter=soteria-functions",
    "test:core": "turbo run test --filter=@soteria/core",
    "test:functions": "turbo run test --filter=soteria-functions",
    "build:web": "turbo run build --filter=@soteria/web",
    "build:mobile": "turbo run build --filter=@soteria/mobile",
    "deploy": "scripts/deploy.sh",
    "deploy:functions": "scripts/deploy.sh --only functions",
    "deploy:rules": "scripts/deploy.sh --only rules",
    "deploy:web": "scripts/deploy.sh --only hosting",
    "emulators": "firebase emulators:start"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
