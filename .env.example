# =============================================================================
# Soteria Assurance — Environment Variable Reference (PUBLIC KEYS ONLY)
# =============================================================================
# Copy the relevant block into the app-local env file it belongs to
# (apps/mobile/.env.local, apps/web/.env.local). NEVER commit real values.
#
# SECRETS DO NOT BELONG HERE.
# ANTHROPIC_API_KEY, SENDGRID_API_KEY, and the Firebase Admin SDK service
# account are managed exclusively via Firebase Secret Manager and accessed in
# Firebase Functions v2 through defineSecret(). They must never appear in
# client config, committed .env files, or this example.
# =============================================================================

# --- Mobile app (Expo) — apps/mobile/.env.local -----------------------------
# All EXPO_PUBLIC_* values are bundled into the client and are NOT secret.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Web app (Next.js) — apps/web/.env.local --------------------------------
# All NEXT_PUBLIC_* values are bundled into the client and are NOT secret.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
